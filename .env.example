# WhatsApp Web account name used by OpenClaw. Use "default" for the attendee's
# personal WhatsApp account.
WHATSAPP_ACCOUNT=default

# Personal Spark / self-chat defaults.
# Replace the placeholder below with the attendee's WhatsApp number in
# international E.164 format, for example +15551234567 or +886912345678.
WHATSAPP_DM_POLICY=allowlist
WHATSAPP_ALLOW_FROM=+15551234567
WHATSAPP_SELF_CHAT_MODE=true

# Groups are disabled for the attendee self-chat flow.
WHATSAPP_GROUP_POLICY=disabled

# Optional allowlists. Use E.164-style phone numbers, comma-separated values,
# or JSON arrays when enabling a dedicated shared demo number.
WHATSAPP_GROUP_ALLOW_FROM=
WHATSAPP_GROUPS=

WHATSAPP_MEDIA_MAX_MB=50
WHATSAPP_SEND_READ_RECEIPTS=true
WHATSAPP_REACTION_LEVEL=minimal

# Local OpenClaw/Ollama defaults.
OPENCLAW_PROFILE=openclaw-whatsapp
OPENCLAW_OLLAMA_MODEL=qwen3.6:27b
OPENCLAW_GATEWAY_PORT=18796
OPENCLAW_GATEWAY_BIND=loopback
